{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/edit_policy.py\"",
            "timeout": 5
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/edit_policy.py\"",
            "timeout": 15
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  }
}
