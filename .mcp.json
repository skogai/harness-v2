{
  "mcpServers": {
    "taskit": {
      "command": "taskit-mcp",
      "env": {
        "TASKIT_URL": "http://localhost:8000"
      }
    },
    "mobile": {
      "command": "npx",
      "args": [
        "-y",
        "@mobilenext/mobile-mcp@latest"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}
